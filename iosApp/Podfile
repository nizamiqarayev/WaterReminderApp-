platform :ios, '14.0'

target 'iosApp' do
  use_frameworks!

  # KMP shared module
  pod 'shared', :path => '../shared'

  # Firebase native iOS frameworks (required by gitlive)
  pod 'FirebaseAuth'
  pod 'FirebaseFirestore'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_phases.each do |phase|
      next unless phase.respond_to?(:shell_script)
      next unless phase.shell_script&.include?('gradlew')

      # Guard: only inject if not already injected (prevents double-injection on re-runs)
      unless phase.shell_script.include?('java_home')
        phase.shell_script = <<~SHELL
          export JAVA_HOME=$(/usr/libexec/java_home)
          export PATH="$JAVA_HOME/bin:$PATH"
          #{phase.shell_script}
        SHELL
      end
    end

    # Fix deployment target warnings from older Firebase/gRPC pods
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end
